<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F8">

    <!-- ================= HEADER ================= -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="#1E3A5F"
        android:gravity="center_vertical"
        android:padding="15dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/alert"
            app:tint="@android:color/white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Disaster Alert"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="10dp"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_bell"
            android:layout_marginEnd="15dp"
            app:tint="@android:color/white" />

        <ImageView
            android:id="@+id/settingsIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_setting"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!-- ================= BOTTOM NAV ================= -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_alignParentBottom="true"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="#1E3A5F"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="5">

        <LinearLayout
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <ImageView
                android:src="@drawable/ic_home"
                android:layout_width="22dp"
                android:layout_height="22dp"
                app:tint="@android:color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="12sp"
                android:textColor="@android:color/white"/>
        </LinearLayout>

        <LinearLayout
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <ImageView
                android:src="@drawable/ic_bell"
                android:layout_width="22dp"
                android:layout_height="22dp"
                app:tint="@android:color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alerts"
                android:textSize="12sp"
                android:textColor="@android:color/white"/>
        </LinearLayout>

        <LinearLayout
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <ImageView
                android:src="@drawable/ic_medical"
                android:layout_width="22dp"
                android:layout_height="22dp"
                 app:tint="@android:color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resources"
                android:textSize="12sp"
                android:textColor="@android:color/white"/>
        </LinearLayout>

        <LinearLayout
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <ImageView

                android:src="@drawable/ic_game"
                android:layout_width="22dp"
                android:layout_height="22dp"
                app:tint="@android:color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Games"
                android:textSize="12sp"
                android:textColor="@android:color/white"/>
        </LinearLayout>

        <LinearLayout
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <ImageView
                android:src="@drawable/ic_profile"
                android:layout_width="22dp"
                android:layout_height="22dp"
                app:tint="@android:color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="12sp"
                android:textColor="@android:color/white"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ================= CONTENT ================= -->
    <ScrollView
        android:layout_below="@id/header"
        android:layout_above="@id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bpge">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- FLOOD WARNING CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="15dp">

                <LinearLayout
                    android:background="@drawable/bg_flood_gradient"
                    android:padding="16dp"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Flood Warning in Your Area"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Heavy rainfall causing flash flooding. Avoid low-lying areas!"
                        android:textColor="@android:color/white"
                        android:layout_marginTop="6dp"/>

                    <Button
                        android:id="@+id/btnEvacuate"
                        android:layout_marginTop="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:text="EVACUATE NOW"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:background="@drawable/evacuate_button_bg"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- MAP CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp">

                <fragment
                    android:id="@+id/map"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"/>

            </androidx.cardview.widget.CardView>

            <!-- EMERGENCY BUTTONS -->
            <!-- ================= EMERGENCY SECTION ================= -->
            <LinearLayout
                android:layout_marginTop="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- Emergency Alerts -->
                <androidx.cardview.widget.CardView
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:id="@+id/btnEmergency"
                        android:background="@drawable/bg_emergency_red"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_warning"
                            app:tint="@android:color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Emergency Alerts"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>


                <!-- Shelter Locations -->
                <androidx.cardview.widget.CardView
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:background="@drawable/bg_shelter_blue"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:id="@+id/btnShelterLocations">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_home"
                            app:tint="@android:color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Shelter Locations"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>


                <!-- SOS Button -->
                <androidx.cardview.widget.CardView
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp">

                    <FrameLayout
                        android:id="@+id/btnSOS"
                        android:background="@drawable/bg_sos_outer"
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <View
                            android:layout_width="75dp"
                            android:layout_height="75dp"
                            android:background="@drawable/bg_sos_inner"/>

                        <TextView
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:text="SOS"
                            android:textColor="@android:color/white"
                            android:textStyle="bold"
                            android:textSize="20sp"/>
                    </FrameLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>
            <!-- ================= GAMES SECTION ================= -->
            <LinearLayout
                android:layout_marginTop="18dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- ================= DISASTER QUIZ CARD ================= -->
                <androidx.cardview.widget.CardView
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="170dp"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Background Image -->
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/disaster_quiz"
                            android:scaleType="centerCrop"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_game_overlay"/>


                        <!-- NEW Badge -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NEW"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"
                            android:background="@drawable/bg_new_badge"
                            android:paddingLeft="8dp"
                            android:paddingRight="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:layout_margin="10dp"
                            android:layout_gravity="top|end"/>

                        <!-- Text Content -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="bottom"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Disaster Quiz"
                                android:textColor="@android:color/white"
                                android:textStyle="bold"
                                android:textSize="14sp"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Test your knowledge with disaster-themed quizzes."
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:layout_marginTop="4dp"/>

                            <Button
                                android:layout_width="70dp"
                                android:layout_height="30dp"
                                android:text="PLAY"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@android:color/white"
                                android:background="@drawable/bg_play_button"
                                android:layout_marginTop="6dp"/>
                        </LinearLayout>

                    </FrameLayout>
                </androidx.cardview.widget.CardView>


                <!-- ================= SAFETY CHALLENGE CARD ================= -->
                <androidx.cardview.widget.CardView
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="170dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- Background Image -->
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/safety_challenge"
                            android:scaleType="centerCrop"/>

                        <!-- Dark Gradient Overlay -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_game_overlay"/>

                        <!-- Text Content -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="bottom"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Safety Challenge"
                                android:textColor="@android:color/white"
                                android:textStyle="bold"
                                android:textSize="14sp"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Make quick decisions in disaster simulations."
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:layout_marginTop="4dp"/>


                            <Button
                                android:layout_width="70dp"
                                android:layout_height="30dp"
                                android:text="PLAY"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@android:color/white"
                                android:background="@drawable/bg_play_button"
                                android:layout_marginTop="6dp"/>
                        </LinearLayout>

                    </FrameLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>



        </LinearLayout>
    </ScrollView>

</RelativeLayout>
